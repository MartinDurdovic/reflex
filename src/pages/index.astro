---
import Layout from '../layouts/Layout.astro';
import { games } from '../games/registry';
import { strings } from '../lib/strings';
---

<Layout>
  <main class="container">
    <p class="dim" style="font-size:0.85rem">{strings.app.tagline}</p>
    <div class="ledger">
      {
        games.map((g, i) => (
          <a class="ledger-row" href={`/play/${g.id}/`} data-test-card={g.id}>
            <span class="lr-index">{String(i + 1).padStart(2, '0')}</span>
            <span class="lr-main">
              <span class="lr-name">{g.name}</span>
              <span class="lr-short">{g.short}</span>
            </span>
            <span class="lr-spark" data-spark aria-hidden="true" />
            <span class="lr-data">
              <span>
                <i>{strings.home.personalBest}</i>
                <span data-best>{strings.home.never}</span>
              </span>
              <span>
                <i>{strings.home.lastPlayed}</i>
                <span data-last>{strings.home.never}</span>
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </main>

  <script>
    import { games } from '../games/registry';
    import { getAttempts } from '../lib/storage';
    import { summarize } from '../lib/stats';
    import { sparklineSvg } from '../engine/chart';

    // fill personal best / last played / sparkline per row from storage
    for (const g of games) {
      getAttempts(g.id).then((attempts) => {
        const row = document.querySelector(`[data-test-card="${g.id}"]`);
        if (!row) return;
        const sum = summarize(attempts, g.lowerIsBetter);
        if (sum.best !== null) {
          row.querySelector('[data-best]')!.textContent = g.formatScore(sum.best);
        }
        if (sum.last) {
          row.querySelector('[data-last]')!.textContent = new Date(
            sum.last.timestamp
          ).toLocaleDateString();
        }
        const recent = attempts.filter((a) => a.valid).slice(-10).map((a) => a.score);
        if (recent.length > 1) {
          row.querySelector('[data-spark]')!.innerHTML = sparklineSvg(recent, 76, 24);
        }
      });
    }
  </script>
</Layout>
