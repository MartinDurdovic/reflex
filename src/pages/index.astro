---
import Layout from '../layouts/Layout.astro';
import { games } from '../games/registry';
import { strings } from '../lib/strings';
---

<Layout>
  <main class="container">
    <p class="dim tagline">{strings.app.tagline}</p>

    <div class="readout-strip">
      <div>
        <span class="label">{strings.stats.totalAttempts}</span>
        <b data-sum-total>0</b>
      </div>
      <div>
        <span class="label">{strings.stats.streak}</span>
        <b data-sum-streak>0</b>
      </div>
      <div>
        <span class="label">{strings.home.today}</span>
        <b data-sum-today>0</b>
      </div>
    </div>

    <p class="section-label">{strings.home.allTests}</p>
    <div class="ledger">
      {
        games.map((g, i) => (
          <a class="ledger-row" href={`/play/${g.id}/`} data-test-card={g.id}>
            <span class="lr-index">{String(i + 1).padStart(2, '0')}</span>
            <span class="lr-main">
              <span class="lr-name">{g.name}</span>
              <span class="badge">{g.scoreUnit}</span>
            </span>
            <span class="lr-short">{g.short}</span>
            <span class="lr-spark" data-spark aria-hidden="true" />
            <span class="lr-data">
              <span>
                <i>{strings.home.personalBest}</i>
                <span data-best>{strings.home.never}</span>
              </span>
              <span>
                <i>{strings.home.lastPlayed}</i>
                <span data-last>{strings.home.never}</span>
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </main>

  <script>
    import { games } from '../games/registry';
    import { getAttempts } from '../lib/storage';
    import { summarize, dailyStreak } from '../lib/stats';
    import { sparklineSvg } from '../engine/chart';
    import { strings } from '../lib/strings';

    // one storage pass powers the summary strip and every ledger row
    Promise.all(games.map((g) => getAttempts(g.id))).then((lists) => {
      const all = lists.flat();
      document.querySelector('[data-sum-total]')!.textContent = String(all.length);
      const streak = dailyStreak(all);
      document.querySelector('[data-sum-streak]')!.textContent =
        `${streak} ${streak === 1 ? strings.stats.day : strings.stats.days}`;
      const today = new Date().toDateString();
      document.querySelector('[data-sum-today]')!.textContent = String(
        all.filter((a) => new Date(a.timestamp).toDateString() === today).length
      );

      games.forEach((g, i) => {
        const attempts = lists[i]!;
        const row = document.querySelector(`[data-test-card="${g.id}"]`);
        if (!row) return;
        const sum = summarize(attempts, g.lowerIsBetter);
        if (sum.best !== null) {
          row.querySelector('[data-best]')!.textContent = g.formatScore(sum.best);
        }
        if (sum.last) {
          row.querySelector('[data-last]')!.textContent = new Date(
            sum.last.timestamp
          ).toLocaleDateString();
        }
        const recent = attempts.filter((a) => a.valid).slice(-10).map((a) => a.score);
        if (recent.length > 1) {
          row.querySelector('[data-spark]')!.innerHTML = sparklineSvg(recent, 76, 24);
        }
      });
    });
  </script>
</Layout>
