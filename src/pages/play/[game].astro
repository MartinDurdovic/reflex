---
// Intro page per test: how-it-works + difficulty selector -> game.
// Games mount into #stage; unimplemented ones show a placeholder.
import Layout from '../../layouts/Layout.astro';
import { games, getGame } from '../../games/registry';
import { strings } from '../../lib/strings';

export function getStaticPaths() {
  return games.map((g) => ({ params: { game: g.id } }));
}

const meta = getGame(Astro.params.game!);
const basicCfg = (meta.config ?? []).filter((f) => !f.advanced);
const advancedCfg = (meta.config ?? []).filter((f) => f.advanced);
const testIndex = String(games.findIndex((g) => g.id === meta.id) + 1).padStart(2, '0');
---

<Layout title={meta.name}>
  <main class="container" id="intro" data-game={meta.id}>
    <p class="protocol">
      {strings.protocol.test} {testIndex} · <b>{meta.scoreUnit}</b>
    </p>
    <h1>{meta.name}</h1>
    <p class="dim">{meta.how}</p>

    <div class="readout-strip" id="record-strip" hidden style="margin-bottom:var(--gap)">
      <div>
        <span class="label">{strings.stats.best}</span>
        <b data-rec-best>—</b>
      </div>
      <div>
        <span class="label">{strings.stats.average}</span>
        <b data-rec-avg>—</b>
      </div>
      <div>
        <span class="label">{strings.stats.totalAttempts}</span>
        <b data-rec-count>—</b>
      </div>
    </div>

    <div class="card" style="display:flex;flex-direction:column;gap:var(--gap)">
      {
        meta.difficulties.length > 0 && (
          <div>
            <label class="dim" style="font-size:0.85rem">{strings.difficulty.label}</label>
            <div id="difficulty-row" style="display:flex;gap:8px;margin-top:6px">
              {meta.difficulties.map((d, i) => (
                <button
                  data-difficulty={d.id}
                  class={i === 0 ? 'primary' : ''}
                  aria-pressed={i === 0 ? 'true' : 'false'}
                >
                  {d.label}
                </button>
              ))}
            </div>
          </div>
        )
      }
      {
        meta.config && (
          <div id="config-rows">
            {basicCfg.map((f) => (
              <div class="cfg-row">
                <span class="dim">{f.label}</span>
                <div class="cfg-ctrl">
                  <button data-cfg-step={f.id} data-dir="-1" aria-label="decrease">−</button>
                  <input
                    type="number"
                    class="mono"
                    data-cfg={f.id}
                    min={f.min}
                    max={f.max}
                    step={f.step ?? 1}
                    value={f.default}
                    inputmode="decimal"
                  />
                  <button data-cfg-step={f.id} data-dir="1" aria-label="increase">+</button>
                </div>
              </div>
            ))}
            {advancedCfg.length > 0 && (
              <details class="cfg-advanced">
                <summary>{strings.config.advanced}</summary>
                <div class="cfg-advanced-rows">
                  {advancedCfg.map((f) => (
                    <div class="cfg-row">
                      <span class="dim">{f.label}</span>
                      <div class="cfg-ctrl">
                        <button data-cfg-step={f.id} data-dir="-1" aria-label="decrease">−</button>
                        <input
                          type="number"
                          class="mono"
                          data-cfg={f.id}
                          min={f.min}
                          max={f.max}
                          step={f.step ?? 1}
                          value={f.default}
                          inputmode="decimal"
                        />
                        <button data-cfg-step={f.id} data-dir="1" aria-label="increase">+</button>
                      </div>
                    </div>
                  ))}
                </div>
              </details>
            )}
          </div>
        )
      }
      {
        meta.implemented ? (
          <button class="primary" id="start-btn" style="font-size:1.1rem">
            {strings.shell.start}
          </button>
        ) : (
          <p class="dim">{strings.comingSoon}</p>
        )
      }
    </div>
  </main>

  <script>
    import { bindIntro } from '../../engine/mount';
    import type { PlayContext } from '../../engine/mount';
    import { getGame } from '../../games/registry';
    import { getSettings, setSetting, getAttempts } from '../../lib/storage';
    import type { Attempt } from '../../lib/storage';
    import { summarize } from '../../lib/stats';

    const introEl = document.getElementById('intro') as HTMLElement;
    const cfgGameId = introEl.dataset.game!;
    const cfgMeta = getGame(cfgGameId);

    // ---- personal record strip (best/avg scoped to the CURRENT
    // difficulty / MOT load, so the preview matches what you'll be
    // rated against; total-attempt count stays test-wide) ----
    let attempts: Attempt[] = [];
    const cfgVal = (id: string): number =>
      Number(document.querySelector<HTMLInputElement>(`[data-cfg="${id}"]`)?.value);
    const currentDifficulty = (): string =>
      document.querySelector<HTMLElement>('#difficulty-row button.primary')?.dataset
        .difficulty ?? '';
    const comparablePred = (): ((a: Attempt) => boolean) => {
      if (cfgGameId === 'mot') {
        const balls = cfgVal('total');
        const targets = cfgVal('targets');
        return (a) => a.params?.['balls'] === balls && a.params?.['targets'] === targets;
      }
      if (cfgMeta.difficulties.length > 1) {
        const d = currentDifficulty();
        return (a) => a.difficulty === d;
      }
      return () => true;
    };
    const renderStrip = (): void => {
      const strip = document.getElementById('record-strip')!;
      if (!attempts.length) {
        strip.hidden = true;
        return;
      }
      strip.hidden = false;
      const sum = summarize(attempts.filter(comparablePred()), cfgMeta.lowerIsBetter);
      strip.querySelector('[data-rec-best]')!.textContent =
        sum.best !== null ? cfgMeta.formatScore(sum.best) : '—';
      strip.querySelector('[data-rec-avg]')!.textContent =
        sum.average !== null ? cfgMeta.formatScore(sum.average) : '—';
      strip.querySelector('[data-rec-count]')!.textContent = String(attempts.length);
    };
    getAttempts(cfgGameId).then((a) => {
      attempts = a;
      renderStrip();
    });

    // difficulty selector toggle (game modules read the pressed button)
    const row = document.getElementById('difficulty-row');
    row?.addEventListener('pointerdown', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-difficulty]');
      if (!btn) return;
      for (const b of row.querySelectorAll('button')) {
        b.classList.toggle('primary', b === btn);
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
      }
      renderStrip();
    });
    if (cfgMeta.config) {
      const CFG_KEY = `${cfgGameId}.config`;
      const fields = cfgMeta.config;
      const inputOf = (id: string) =>
        document.querySelector<HTMLInputElement>(`[data-cfg="${id}"]`)!;
      const currentValues = (): Record<string, number> =>
        Object.fromEntries(fields.map((f) => [f.id, Number(inputOf(f.id).value)]));

      /** clamp every field to [min, effectiveMax] on its step grid */
      const clampAll = (): Record<string, number> => {
        const vals = currentValues();
        for (const f of fields) {
          const el = inputOf(f.id);
          const step = f.step ?? 1;
          const max = Math.min(f.max, f.dynamicMax ? f.dynamicMax(vals) : f.max);
          let v = Number(el.value);
          if (!Number.isFinite(v)) v = f.default;
          v = Number((Math.round(v / step) * step).toFixed(2));
          v = Math.min(max, Math.max(f.min, v));
          el.value = String(v);
          el.max = String(max);
          vals[f.id] = v;
        }
        return vals;
      };

      const save = () => {
        setSetting(CFG_KEY, clampAll());
        renderStrip(); // MOT best/avg are scoped to the current load
      };

      // restore saved preferences (defaults are pre-rendered)
      getSettings().then((s) => {
        const saved = s[CFG_KEY] as Record<string, number> | undefined;
        if (saved) {
          for (const f of fields) {
            if (typeof saved[f.id] === 'number') inputOf(f.id).value = String(saved[f.id]);
          }
        }
        clampAll();
        renderStrip();
      });

      document.getElementById('config-rows')!.addEventListener('pointerdown', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-cfg-step]');
        if (!btn) return;
        const field = fields.find((f) => f.id === btn.dataset.cfgStep)!;
        const el = inputOf(field.id);
        el.value = String(Number(el.value) + Number(btn.dataset.dir) * (field.step ?? 1));
        save();
      });
      for (const f of fields) {
        inputOf(f.id).addEventListener('change', save);
      }
    }

    // lazy-load only this page's game module (Vite code-splits each)
    const loaders: Record<string, () => Promise<{ run: (ctx: PlayContext) => void | Promise<void> }>> = {
      'reaction-f1': () => import('../../games/reaction-f1/game'),
      mot: () => import('../../games/mot/game'),
      'go-nogo': () => import('../../games/go-nogo/game'),
      'digit-span': () => import('../../games/digit-span/game'),
      rotation: () => import('../../games/rotation/game'),
    };
    const gameId = document.getElementById('intro')!.dataset.game!;
    loaders[gameId]?.().then((mod) => bindIntro(gameId, mod.run));
  </script>
</Layout>
