---
import '../styles/theme.css';
import { strings } from '../lib/strings';

interface Props {
  title?: string;
  /** hide header nav (used by game pages so chrome can't be mis-tapped) */
  bare?: boolean;
}
const { title, bare = false } = Astro.props;
const pageTitle = title ? `${title} · ${strings.app.name}` : strings.app.name;
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no"
    />
    <title>{pageTitle}</title>
    <meta name="theme-color" content="#131110" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link
      rel="preload"
      href="/fonts/IBMPlexMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/IBMPlexMono-SemiBold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body>
    {
      !bare && (
        <header class="app-header">
          <a href="/" class="brand">
            <span class="brand-lamps" aria-hidden="true"><i /><i /><i /><i /><i /></span>
            {strings.app.name}
          </a>
          <nav>
            <a href="/" aria-current={current === '/' ? 'page' : undefined}>
              {strings.nav.home}
            </a>
            <a href="/stats/" aria-current={current.startsWith('/stats') ? 'page' : undefined}>
              {strings.nav.stats}
            </a>
            <a href="/settings/" aria-current={current.startsWith('/settings') ? 'page' : undefined}>
              {strings.nav.settings}
            </a>
          </nav>
        </header>
      )
    }
    <slot />
    <script>
      // Register the service worker (generated at build time; absent in
      // dev) and auto-apply updates: promote a waiting SW and reload —
      // but never while a game trial is live (body.game-locked).
      if ('serviceWorker' in navigator && import.meta.env.PROD) {
        const hadController = !!navigator.serviceWorker.controller;
        let reloaded = false;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          // first-ever install also fires this (clients.claim) — only
          // reload when an update actually replaced a previous SW, and
          // never yank a tab that is mid-trial (e.g. promoted elsewhere)
          if (!hadController || reloaded) return;
          if (document.body.classList.contains('game-locked')) return;
          reloaded = true;
          location.reload();
        });

        navigator.serviceWorker
          .register('/sw.js')
          .then((reg) => {
            const promote = (): void => {
              if (!document.body.classList.contains('game-locked')) {
                reg.waiting?.postMessage('skip-waiting');
              }
            };
            promote(); // update already waiting from a previous visit
            reg.addEventListener('updatefound', () => {
              reg.installing?.addEventListener('statechange', promote);
            });
            // a trial just ended -> safe moment to apply a pending update
            document.addEventListener('visibilitychange', promote);
          })
          .catch(() => {});
      }
    </script>
  </body>
</html>
